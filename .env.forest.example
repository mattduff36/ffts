# Forest Farm Tree Services production environment
# Copy this file to .env.local in the ffts project and fill in the blank values.
# Do not commit populated env files or real secrets.

# ============================================================================
# APP MODE
# ============================================================================
APP_MODE=production
NEXT_PUBLIC_APP_MODE=production

# ============================================================================
# SUPABASE CONFIGURATION - REQUIRED
# ============================================================================
# Use the dedicated Forest Farm Supabase project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Direct/non-pooling connection string for migrations and validation scripts.
POSTGRES_URL_NON_POOLING=
POSTGRES_URL=

# ============================================================================
# SESSION SIGNING - REQUIRED
# ============================================================================
# Generate unique strong values for Forest Farm; do not reuse demo/project secrets.
APP_SESSION_SECRET=
APP_SESSION_HASH_SECRET=

# ============================================================================
# PUBLIC URLS
# ============================================================================
# Local development default. In Vercel, set both to the production FFTS URL.
NEXT_PUBLIC_APP_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:4000

# ============================================================================
# FOREST FARM BRANDING
# ============================================================================
NEXT_PUBLIC_APP_NAME=Forest Farm Tree Services Operations
NEXT_PUBLIC_SHORT_APP_NAME=Forest Farm
NEXT_PUBLIC_COMPANY_NAME=Forest Farm Tree Services
NEXT_PUBLIC_COMPANY_ADDRESS=Forest Farm Tree Services, East Midlands
NEXT_PUBLIC_COMPANY_REGISTRATION=Generated by Forest Farm Tree Services Operations
NEXT_PUBLIC_SUPPORT_PHONE=Telephone: 07860650405
NEXT_PUBLIC_LOGO_PATH=/images/forest-farm/logo.svg
NEXT_PUBLIC_FAVICON_PATH=/images/forest-farm/favicon.svg
NEXT_PUBLIC_BRAND_COLOR=#F1D64A
NEXT_PUBLIC_BRAND_COLOR_HOVER=#CFB840
NEXT_PUBLIC_BRAND_COLOR_LIGHT=#FCF8DE
NEXT_PUBLIC_PWA_BACKGROUND_COLOR=#0F172A

# Contact addresses. Replace these before handing over if Forest Farm wants
# support/admin mail routed to their own inboxes.
NEXT_PUBLIC_SUPPORT_EMAIL=admin@mpdee.co.uk
NEXT_PUBLIC_ADMIN_EMAIL=admin@mpdee.co.uk
SUPPORT_EMAIL=admin@mpdee.co.uk
ADMIN_EMAIL=admin@mpdee.co.uk
TEMPLATE_SUPERADMIN_EMAIL=admin@mpdee.co.uk

# ============================================================================
# PRODUCTION SUPERADMIN BOOTSTRAP
# ============================================================================
# Used only by scripts/production/bootstrap-forest-farm.ts.
# Set the password locally for the one-time bootstrap run, then remove it.
FOREST_FARM_SUPERADMIN_EMAIL=admin@mpdee.co.uk
FOREST_FARM_SUPERADMIN_PASSWORD=

# ============================================================================
# EMAIL / NOTIFICATIONS - OPTIONAL BUT RECOMMENDED
# ============================================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_API_KEY_2=
RESEND_FROM_EMAIL_2=

# ============================================================================
# MAPS / VEHICLE PROVIDERS - OPTIONAL
# ============================================================================
NEXT_PUBLIC_MAPTILER_API_KEY=
DVLA_API_PROVIDER=
DVLA_API_KEY=
DVLA_API_BASE_URL=
MOT_API_CLIENT_ID=
MOT_API_CLIENT_SECRET=
MOT_API_SCOPE=
MOT_API_ACCESS_TOKEN_URL=
MOT_API_KEY=
MOT_API_BASE_URL=
FLEETSMART_BASE_URL=
FLEETSMART_CLIENT_ID=
FLEETSMART_API_KEY=
CRON_SECRET=

# ============================================================================
# FEATURE FLAGS
# ============================================================================
NEXT_PUBLIC_ORG_HIERARCHY_V2_ENABLED=false
NEXT_PUBLIC_ORG_HIERARCHY_ADMIN_UI_ENABLED=false
NEXT_PUBLIC_ORG_HIERARCHY_DEFAULT_TEAM_MODE=legacy
NEXT_PUBLIC_PRIORITY_MANAGER_EMAIL=admin@mpdee.co.uk
NEXT_PUBLIC_DEBUG_ACCESS_EMAIL=admin@mpdee.co.uk
NEXT_PUBLIC_ABSENCE_MANAGE_UNLOCK_CODE=
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
