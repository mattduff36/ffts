# Environment Variables Template
# Copy this file to .env.local and fill in the values

# ============================================================================
# SUPABASE CONFIGURATION (Required)
# ============================================================================
# Your Supabase project URL
# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anonymous/public key
# Example: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase service role key.
# Never expose this in client code or NEXT_PUBLIC variables.
SUPABASE_SERVICE_ROLE_KEY=

# Optional Supabase JWT signing secret for app-session token verification.
SUPABASE_JWT_SECRET=

# ============================================================================
# DATABASE CONFIGURATION (Optional - for scripts only)
# ============================================================================
# Direct Postgres connection URL (non-pooling)
# Used by migration and maintenance scripts
# Example: postgresql://postgres:[password]@db.abcdefghijklmnop.supabase.co:5432/postgres
POSTGRES_URL_NON_POOLING=

# ============================================================================
# EMAIL CONFIGURATION (Optional - for error reporting)
# ============================================================================
# Resend API key for sending error notification emails
# Get your key from: https://resend.com/api-keys
RESEND_API_KEY=

# Default from address for primary Resend key
RESEND_FROM_EMAIL=

# Dedicated Resend API key and from address for quotes/customers mail
RESEND_API_KEY_2=
RESEND_FROM_EMAIL_2=

# Admin email address to receive error notifications
# Example: admin@example.com
ADMIN_EMAIL=

# Public app URL used by emails, tests, and deployment callbacks.
NEXT_PUBLIC_APP_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:4000
SUPPORT_EMAIL=support@example.test

# ============================================================================
# ANALYTICS (Optional)
# ============================================================================
# Vercel Analytics ID (auto-configured if deploying to Vercel)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# ============================================================================
# TEMPLATE PLACEHOLDERS (Optional - replace per client)
# ============================================================================
# App mode controls setup/demo guardrails.
# Values: development | template | demo | production
APP_MODE=development
NEXT_PUBLIC_APP_MODE=development

# Central branding used by UI, emails, PDFs, manifests, and setup docs.
NEXT_PUBLIC_APP_NAME=FieldOps Template
NEXT_PUBLIC_SHORT_APP_NAME=FieldOps
NEXT_PUBLIC_COMPANY_NAME=Example Client Ltd
NEXT_PUBLIC_COMPANY_ADDRESS=Example House, Template Street, Example Town
NEXT_PUBLIC_SUPPORT_EMAIL=support@example.test
NEXT_PUBLIC_ADMIN_EMAIL=template-admin@example.com
NEXT_PUBLIC_LOGO_PATH=/images/logo.svg
NEXT_PUBLIC_FAVICON_PATH=/favicon.svg
NEXT_PUBLIC_BRAND_COLOR=#F1D64A
NEXT_PUBLIC_BRAND_COLOR_HOVER=#D4B83A
NEXT_PUBLIC_PWA_BACKGROUND_COLOR=#0f172a

# Placeholder account used in seed data/tests and legacy superadmin checks.
TEMPLATE_SUPERADMIN_EMAIL=template-admin@example.com

# Demo mode only. Use a fake/reserved domain and a dedicated demo database.
NEXT_PUBLIC_DEMO_EMAIL_DOMAIN=demo.example.test
# Required in demo mode for destructive reset/wipe guardrails.
# Example: abcdefghijklmnopqrst from https://abcdefghijklmnopqrst.supabase.co
DEMO_SUPABASE_PROJECT_REF=
DEMO_RESET_CONFIRM=

# Public placeholder for the timesheet adjustment "recommended manager" behavior.
NEXT_PUBLIC_PRIORITY_MANAGER_EMAIL=priority.manager@example.com

# Public placeholder for delegated debug-console access.
NEXT_PUBLIC_DEBUG_ACCESS_EMAIL=debug.user@example.com

# Public unlock code for protected absence-management tabs.
# Change this for each client if this UI flow is enabled.
NEXT_PUBLIC_ABSENCE_MANAGE_UNLOCK_CODE=template-unlock-code

# Session signing secret for app-auth flows.
APP_SESSION_SECRET=
APP_SESSION_HASH_SECRET=

# ============================================================================
# OPTIONAL VEHICLE / MAP PROVIDERS
# ============================================================================
NEXT_PUBLIC_MAPTILER_API_KEY=
DVLA_API_PROVIDER=
DVLA_API_KEY=
DVLA_API_BASE_URL=
MOT_API_CLIENT_ID=
MOT_API_CLIENT_SECRET=
MOT_API_SCOPE=
MOT_API_ACCESS_TOKEN_URL=
MOT_API_KEY=
MOT_API_BASE_URL=
FLEETSMART_BASE_URL=
FLEETSMART_CLIENT_ID=
FLEETSMART_API_KEY=

# ============================================================================
# ORG HIERARCHY V2 (Optional - feature flags)
# ============================================================================
# Enables hierarchy-based absence approval filtering and checks.
# Default in code: false
NEXT_PUBLIC_ORG_HIERARCHY_V2_ENABLED=false

# Enables hierarchy controls in Admin > Users UI.
# Default in code: false
NEXT_PUBLIC_ORG_HIERARCHY_ADMIN_UI_ENABLED=false

# Default team mode when no DB team mode is found.
# Values: legacy | org_v2
# Default in code: legacy
NEXT_PUBLIC_ORG_HIERARCHY_DEFAULT_TEAM_MODE=legacy

# ============================================================================
# ENVIRONMENT
# ============================================================================
# Node environment (automatically set by Next.js)
# Values: development | production | test
NODE_ENV=development

# ============================================================================
# NOTES
# ============================================================================
# 1. Required variables must be set for the app to work
# 2. Optional variables enable additional features
# 3. Never commit .env.local to version control
# 4. Keep your keys secure and rotate them regularly
# 5. Scripts requiring database access need POSTGRES_URL_NON_POOLING
